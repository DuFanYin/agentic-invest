# Required: LLM provider ("openrouter" or "openai")
LLM_PROVIDER=openai

# Required: API key for the selected provider
# - openrouter -> sk-or-v1-...
# - openai     -> sk-...
LLM_API_KEY=your_llm_api_key_here

# Optional: only used when LLM_PROVIDER=openrouter
# Used for OpenRouter app attribution headers.
# LLM_HTTP_REFERER=http://localhost:8000
# LLM_APP_TITLE=agentic-invest

# Optional: Tavily API key for web/news search
# If missing, web search degrades gracefully.
TAVILY_API_KEY=tvly-...