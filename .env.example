# Required: OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the model (leave blank to use the free fallback chain:
#   openai/gpt-oss-20b:free → openai/gpt-oss-120b:free → nvidia/nemotron-3-super-120b-a12b:free)
# OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Optional: OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=agentic-invest

# Optional: Tavily API key (Phase 2 — web/news search)
# TAVILY_API_KEY=tvly-...
