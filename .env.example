# Required: LLM provider ("openrouter" or "openai")
LLM_PROVIDER=openai

# Required: API key for the selected provider
# - openrouter -> sk-or-v1-...
# - openai     -> sk-...
LLM_API_KEY=your_llm_api_key_here

# Optional: Tavily API key for web/news search
# If missing, web search degrades gracefully.
TAVILY_API_KEY=tvly-...


FRED_API_KEY=